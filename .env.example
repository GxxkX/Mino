# =============================================================================
# Mino Configuration
# Copy to .env and fill in your values, then: docker compose up -d
# =============================================================================

# ---- Service Ports (host-side) ----
# Only the backend API and web UI are exposed to the host.
# Infrastructure services communicate internally over mino_net.
APP_PORT=8000
WEB_PORT=3000

# ---- App Configuration ----
APP_ENV=production
APP_DEBUG=false

# ---- Database (PostgreSQL) ----
DB_NAME=mino
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL_MODE=disable

# ---- Redis ----
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ---- JWT ----
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE=48h
JWT_REFRESH_TOKEN_EXPIRE=168h

# ---- Default Admin Account ----
ADMIN_USERNAME=mino
ADMIN_PASSWORD=admin

# ---- LLM ----
# Supported providers: openai, zhipu, ollama
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---- Milvus (Vector Database) ----
# Hosts are auto-resolved inside docker compose; these are only needed
# if you run the backend outside of compose.
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default
MILVUS_CONVERSATIONS_COLLECTION=conversations
MILVUS_MEMORIES_COLLECTION=memories

# ---- MinIO (Object Storage) ----
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=
# Internal hostname used by the web proxy to validate MinIO audio URLs (SSRF guard).
# Set to the MinIO service hostname, e.g. "minio" inside docker compose.
MINIO_INTERNAL_HOST=minio

# ---- Typesense (Full-text Search) ----
TYPESENSE_API_KEY=your_typesense_api_key

# ---- LangSmith (optional, LLM observability) ----
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mino-backend-chat
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- LangSmith Prompt Management (optional) ----
OMI_LANGSMITH_AGENTIC_PROMPT_NAME=mino-agentic-system
OMI_LANGSMITH_PROMPT_CACHE_TTL_SECONDS=300

# ---- STT (Speech-to-Text) ----
STT_PROVIDER=whisper
STT_WHISPER_API_KEY=your_whisper_api_key
STT_WHISPER_MODEL=tiny-zh
